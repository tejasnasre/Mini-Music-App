{
  "name": "mini-music-backend",
  "module": "src/index.ts",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "lint": "tsc --noEmit",
    "preview": "bun dist/index.js",
    "hls:generate": "bun src/utils/mp3tochunks.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "typescript": "^5"
  }
}
